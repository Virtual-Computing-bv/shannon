{
  "name": "@nahayat/pentest-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Nahayat-branded web portal around Shannon Lite. Single-tenant, deployed per customer.",
  "scripts": {
    "dev": "concurrently -k -n server,web -c green,cyan \"tsx watch src/server/index.ts\" \"vite\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "check": "tsc -p tsconfig.server.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.8",
    "execa": "^9.5.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.1",
    "@types/bcryptjs": "^2.4.6",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "vite": "^6.0.7",
    "tsx": "^4.19.2",
    "concurrently": "^9.1.2",
    "typescript": "^5.9.3"
  }
}
